{
    "name": "mdalikadar/php-cli-toolkit",
    "description": "A toolkit to build and manage PHP based command line application.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "PhpCliToolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpCliToolkit\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "MD ALI KADAR"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    }
}
